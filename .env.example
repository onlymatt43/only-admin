# only-admin-main — Environment template
# Source of truth pour le contenu (Bunny + Turso).
# Phase 1: canonical naming avec aliases legacy temporaires.

NODE_ENV=development

# Admin UI auth
ADMIN_TOKEN=replace_with_admin_token
ADMIN_TOTP_SECRET=
ADMIN_SESSION_SECRET=

# Cle de service pour appels sortants signes (canonical)
ADMIN_SERVICE_KEY=replace_with_strong_key
# Legacy alias (compat — sera retire apres migration)
# CHAUD_DEVANT_SERVICE_KEY=

# Turso (DB propre)
TURSO_DB_URL=libsql://your-db.turso.io
TURSO_DB_TOKEN=your_turso_token

# Bunny Stream — Public library (canonical)
BUNNY_PUBLIC_LIBRARY_ID=
BUNNY_PUBLIC_API_KEY=
BUNNY_PUBLIC_PULL_ZONE_URL=
# Legacy aliases
# BUNNY_LIBRARY_ID=
# BUNNY_API_KEY=

# Bunny Stream — Private library
BUNNY_PRIVATE_LIBRARY_ID=
BUNNY_PRIVATE_API_KEY=
BUNNY_PRIVATE_PULL_ZONE_URL=

# Bunny CDN signing (canonical)
BUNNY_CDN_SIGNING_KEY=
# Legacy aliases
# BUNNY_TOKEN_KEY=
# BUNNY_SIGNING_KEY=

# Bunny Storage (photos)
BUNNY_STORAGE_NAME=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_PULL_ZONE_URL=

# Webhooks sortants — project-links (canonical)
PROJECT_ROUTES_URL=
# Legacy alias: PROJECT_LINKS_URL=
WEBHOOK_SECRET_PROJECT_LINKS=
# Legacy aliases: PROJECT_LINKS_REVALIDATE_SECRET, PROJECT_ROUTES_REVALIDATE_SECRET

# Webhooks sortants — super-videotheque (canonical)
CATALOG_SYNC_URL=
# Legacy alias: SUPER_VIDEOTHEQUE_URL=
WEBHOOK_SECRET_SUPER_VIDEOTHEQUE=
# Legacy aliases: SUPER_VIDEOTHEQUE_WEBHOOK_SECRET, CATALOG_SYNC_WEBHOOK_SECRET

# Webhook sortant — viewer-only (si service separe)
VIEWER_SYNC_URL=

# Strict mode (warn-only en Phase 1, true en Phase 3+)
ENV_STRICT_MODE=false
